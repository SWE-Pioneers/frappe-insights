								"column": {
									"type": "column",
									"column_name": "docstatus"
								},
								"operator": "=",
								"value": 1
							},
							{
								"column": {
									"type": "column",
									"column_name": "payment_type"
								},
								"operator": "in",
								"value": [
									"Receive",
									"Pay"
								]
							}
						]
					},
					{
						"type": "mutate",
						"new_name": "flow",
						"data_type": "String",
						"expression": {
							"type": "expression",
							"expression": "if_else(payment_type == 'Receive', 'Cash In', 'Cash Out')"
						}
					},
					{
						"type": "mutate",
						"new_name": "amount",
						"data_type": "Decimal",
						"expression": {
							"type": "expression",
							"expression": "if_else(payment_type == 'Receive', base_received_amount, base_paid_amount)"
						}
					},
					{
						"type": "mutate",
						"new_name": "net_amount",
						"data_type": "Decimal",
						"expression": {
							"type": "expression",
							"expression": "if_else(payment_type == 'Receive', base_received_amount, - base_paid_amount)"
						}
					}
				]
			},

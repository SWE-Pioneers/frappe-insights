							}
						],
						"join_condition": {
							"join_expression": {
								"type": "expression",
								"expression": "(t1.item_code == t2.parent) & (t1.warehouse == t2.warehouse)"
							}
						}
					},
					{
						"type": "filter_group",
						"logical_operator": "And",
						"filters": [
							{
								"column": {
									"type": "column",
									"column_name": "projected_qty"
								},
								"operator": "<",
								"value": {
									"type": "column",
									"column_name": "warehouse_reorder_level"
								}
							}
						]
					},
					{
						"type": "select",

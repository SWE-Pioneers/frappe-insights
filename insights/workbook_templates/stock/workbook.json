			"template-query-stock-movements": {
				"name": "template-query-stock-movements",
				"title": "Stock Movements",
				"workbook": "template-stock-inventory-health",
				"folder": null,
				"sort_order": 1,
				"use_live_connection": 1,
				"is_script_query": 0,
				"is_builder_query": 1,
				"is_native_query": 0,
				"operations": [
					{
						"type": "source",
						"table": {
							"type": "table",
							"data_source": "Site DB",
							"table_name": "tabStock Ledger Entry"
						}
					},
					{
						"type": "filter_group",
						"logical_operator": "And",
						"filters": [
							{
								"column": {
									"type": "column",
									"column_name": "is_cancelled"
								},
								"operator": "=",
								"value": 0
							}
						]
					},
					{
						"type": "mutate",
						"new_name": "incoming_value",
						"data_type": "Decimal",
						"expression": {
							"type": "expression",
							"expression": "if_else(actual_qty > 0, stock_value_difference, 0)"
						}
					},
					{
						"type": "mutate",
						"new_name": "outgoing_value",
						"data_type": "Decimal",
						"expression": {
							"type": "expression",
							"expression": "if_else(actual_qty < 0, abs(stock_value_difference), 0)"
						}
					},
					{
						"type": "select",
						"column_names": [
							"posting_date",
							"company",
							"warehouse",
							"item_code",
							"voucher_type",
							"actual_qty",
							"stock_value_difference",
							"incoming_value",
							"outgoing_value"
						]
					}
				]
			},
			"template-query-stock-last-movement": {
				"name": "template-query-stock-last-movement",
				"title": "Last Movement Per Item",
				"workbook": "template-stock-inventory-health",
				"folder": null,
				"sort_order": 2,
				"use_live_connection": 1,

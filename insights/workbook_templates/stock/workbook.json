								"aggregation": "max"
							}
						],
						"dimensions": [
							{
								"dimension_name": "item_code",
								"column_name": "item_code",
								"data_type": "String"
							}
						]
					}
				]
			},
			"template-query-stock-ageing": {
				"name": "template-query-stock-ageing",
				"title": "Stock Ageing",
				"workbook": "template-stock-inventory-health",
				"folder": null,
				"sort_order": 3,
				"use_live_connection": 1,
				"is_script_query": 0,
				"is_builder_query": 1,
				"is_native_query": 0,
				"operations": [
					{
						"type": "source",
						"table": {
							"type": "table",
							"data_source": "Site DB",
							"table_name": "tabBin"
						}
					},
					{
						"type": "join",
						"join_type": "inner",
						"table": {
							"type": "query",
							"workbook": "template-stock-inventory-health",
							"query_name": "template-query-stock-last-movement"
						},
						"select_columns": [
							{
								"type": "column",
								"column_name": "last_movement_date"
							}
						],
						"join_condition": {
							"left_column": {
								"type": "column",
								"column_name": "item_code"
							},
							"right_column": {
								"type": "column",
								"column_name": "item_code"
							}
						}
					},
					{
						"type": "mutate",
						"new_name": "days_since_movement",
						"data_type": "Integer",
						"expression": {
							"type": "expression",
							"expression": "date_diff(today(), last_movement_date, \"day\")"
						}
					},
					{
						"type": "mutate",
						"new_name": "ageing_bucket",
						"data_type": "String",
						"expression": {
							"type": "expression",
							"expression": "cases((days_since_movement <= 30, \"1. 0-30 days\"), (days_since_movement <= 90, \"2. 31-90 days\"), (days_since_movement <= 180, \"3. 91-180 days\"), else_=\"4. 180+ days\")"
						}
					},
					{
						"type": "select",
						"column_names": [
							"item_code",
							"warehouse",
							"company",
							"actual_qty",
							"stock_value",
							"last_movement_date",
							"days_since_movement",
							"ageing_bucket"
						]
					}
				]
			},

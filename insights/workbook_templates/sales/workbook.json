						"type": "sql",
						"data_source": "Site DB",
						"raw_sql": "SELECT '1. Total' AS stage, COUNT(*) AS quotations FROM `tabQuotation` WHERE docstatus = 1\nUNION ALL\nSELECT '2. Ordered' AS stage, COUNT(*) AS quotations FROM `tabQuotation` WHERE docstatus = 1 AND status = 'Ordered'"
